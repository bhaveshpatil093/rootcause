# Example environment variables
# Copy this file to .env.local and fill in the values

# ---------------------------------------------------------
# Cognee / LLM Configuration
# ---------------------------------------------------------

# The API Key for NVIDIA Nim (or OpenAI). Required for Cognee ingestion graph building.
# NEVER prefix these with NEXT_PUBLIC_ to ensure they do not leak to the browser.
NVIDIA_API_KEY="your-nvidia-nim-api-key-here"

# Advanced Cognee overrides (defaults shown below)
# COGNEE_LLM_PROVIDER="openai"
# COGNEE_LLM_MODEL="meta/llama-3.1-8b-instruct"
# COGNEE_LLM_ENDPOINT="https://integrate.api.nvidia.com/v1"
# COGNEE_EMBEDDING_PROVIDER="onnx"
# COGNEE_EMBEDDING_MODEL="bge-small-en-v1.5"
